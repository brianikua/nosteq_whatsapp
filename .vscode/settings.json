  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "name": "Comments",
        "scope": ["comment", "punctuation.definition.comment"],
        "settings": { "foreground": "#3a5068", "fontStyle": "italic" }
      },
      {
        "name": "Keywords & Control Flow",
        "scope": [
          "keyword",
          "keyword.control",
          "keyword.operator.new",
          "keyword.operator.expression",
          "storage.type",
          "storage.modifier"
        ],
        "settings": { "foreground": "#38bdf8" }
      },
      {
        "name": "Strings",
        "scope": ["string", "string.template", "string.quoted"],
        "settings": { "foreground": "#4ade80" }
      },
      {
        "name": "String Escape / Template Expression",
        "scope": [
          "constant.character.escape",
          "punctuation.definition.template-expression"
        ],
        "settings": { "foreground": "#22c55e" }
      },
      {
        "name": "Numbers",
        "scope": ["constant.numeric"],
        "settings": { "foreground": "#fbbf24" }
      },
      {
        "name": "Constants & Booleans",
        "scope": [
          "constant.language",
          "constant.language.boolean",
          "constant.language.null",
          "constant.language.undefined"
        ],
        "settings": { "foreground": "#fbbf24" }
      },
      {
        "name": "Functions & Methods",
        "scope": [
          "entity.name.function",
          "meta.function-call",
          "support.function",
          "meta.method-call entity.name.function"
        ],
        "settings": { "foreground": "#22c55e" }
      },
      {
        "name": "Function Parameters",
        "scope": ["variable.parameter"],
        "settings": { "foreground": "#a8bfd4", "fontStyle": "italic" }
      },
      {
        "name": "Classes & Types",
        "scope": [
          "entity.name.class",
          "entity.name.type",
          "entity.name.type.class",
          "support.class",
          "support.type"
        ],
        "settings": { "foreground": "#7dd3fc" }
      },
      {
        "name": "Type Annotations",
        "scope": [
          "meta.type.annotation",
          "meta.type.parameters",
          "entity.name.type.ts",
          "support.type.primitive"
        ],
        "settings": { "foreground": "#38bdf8" }
      },
      {
        "name": "Interfaces & Enums",
        "scope": ["entity.name.type.interface", "entity.name.type.enum"],
        "settings": { "foreground": "#67e8f9" }
      },
      {
        "name": "Variables",
        "scope": ["variable", "variable.other", "variable.other.object"],
        "settings": { "foreground": "#cdd9e5" }
      },
      {
        "name": "Object Properties",
        "scope": [
          "variable.other.property",
          "support.variable.property",
          "meta.object-literal.key"
        ],
        "settings": { "foreground": "#a8bfd4" }
      },
      {
        "name": "Operators",
        "scope": ["keyword.operator"],
        "settings": { "foreground": "#38bdf8" }
      },
      {
        "name": "Punctuation",
        "scope": [
          "punctuation",
          "punctuation.separator",
          "punctuation.terminator",
          "punctuation.accessor"
        ],
        "settings": { "foreground": "#5a7a94" }
      },
      {
        "name": "HTML Tags",
        "scope": ["entity.name.tag", "meta.tag.sgml"],
        "settings": { "foreground": "#38bdf8" }
      },
      {
        "name": "HTML/JSX Attributes",
        "scope": [
          "entity.other.attribute-name",
          "meta.tag entity.other.attribute-name"
        ],
        "settings": { "foreground": "#22c55e" }
      },
      {
        "name": "CSS Properties",
        "scope": ["support.type.property-name.css", "meta.property-name"],
        "settings": { "foreground": "#22c55e" }
      },
      {
        "name": "CSS Values",
        "scope": ["support.constant.property-value.css", "meta.property-value"],
        "settings": { "foreground": "#fbbf24" }
      },
      {
        "name": "CSS Selectors",
        "scope": [
          "entity.other.attribute-name.class.css",
          "entity.other.attribute-name.id.css"
        ],
        "settings": { "foreground": "#7dd3fc" }
      },
      {
        "name": "Imports & Modules",
        "scope": [
          "keyword.control.import",
          "keyword.control.export",
          "keyword.control.from",
          "keyword.control.as"
        ],
        "settings": { "foreground": "#c084fc" }
      },
      {
        "name": "Decorators",
        "scope": [
          "meta.decorator",
          "punctuation.decorator",
          "entity.name.function.decorator"
        ],
        "settings": { "foreground": "#e879f9", "fontStyle": "italic" }
      },
      {
        "name": "Regex",
        "scope": ["string.regexp"],
        "settings": { "foreground": "#fbbf24" }
      },
      {
        "name": "JSON Keys",
        "scope": ["support.type.property-name.json"],
        "settings": { "foreground": "#38bdf8" }
      },
      {
        "name": "JSON Values",
        "scope": ["string.quoted.double.json"],
        "settings": { "foreground": "#4ade80" }
      },
      {
        "name": "Markdown Headings",
        "scope": ["markup.heading", "entity.name.section.markdown"],
        "settings": { "foreground": "#22c55e", "fontStyle": "bold" }
      },
      {
        "name": "Markdown Bold",
        "scope": ["markup.bold"],
        "settings": { "foreground": "#cdd9e5", "fontStyle": "bold" }
      },
      {
        "name": "Markdown Italic",
        "scope": ["markup.italic"],
        "settings": { "foreground": "#a8bfd4", "fontStyle": "italic" }
      },
      {
        "name": "Markdown Code",
        "scope": ["markup.inline.raw", "markup.fenced_code.block"],
        "settings": { "foreground": "#4ade80" }
      },
      {
        "name": "Markdown Links",
        "scope": ["markup.underline.link", "meta.link"],
        "settings": { "foreground": "#38bdf8" }
      },
      {
        "name": "Invalid / Deprecated",
        "scope": ["invalid", "invalid.deprecated"],
        "settings": { "foreground": "#f87171", "fontStyle": "strikethrough" }
      }
    ]
  },
  "editor.semanticTokenColorCustomizations": {
    "enabled": true,
    "rules": {
      "class": { "foreground": "#7dd3fc" },
      "interface": { "foreground": "#67e8f9" },
      "enum": { "foreground": "#67e8f9" },
      "function": { "foreground": "#22c55e" },
      "method": { "foreground": "#22c55e" },
      "property": { "foreground": "#a8bfd4" },
      "variable": { "foreground": "#cdd9e5" },
      "parameter": { "foreground": "#a8bfd4", "fontStyle": "italic" },
      "type": { "foreground": "#38bdf8" },
      "namespace": { "foreground": "#c084fc" },
      "decorator": { "foreground": "#e879f9", "fontStyle": "italic" },
      "keyword": { "foreground": "#38bdf8" },
      "string": { "foreground": "#4ade80" },
      "number": { "foreground": "#fbbf24" },
      "comment": { "foreground": "#3a5068", "fontStyle": "italic" },
      "regexp": { "foreground": "#fbbf24" }
    }
  }
}
